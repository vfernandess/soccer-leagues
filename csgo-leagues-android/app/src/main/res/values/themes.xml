<resources>
    <style name="Theme.CsgoLeagues" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/app_background</item>
        <item name="android:windowBackground">@color/app_background</item>
    </style>

    <style name="Theme.CsgoLeagues.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/app_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo_system</item>
        <item name="postSplashScreenTheme">@style/Theme.CsgoLeagues</item>
    </style>
</resources>
